{% for event in events %}                is {{ event_class }}.{{ event.name }} -> {{ event.handler }}
{% endfor %}            }
        }
    }

{% endif %}    {{ screen_name }}Content(
        uiState = uiState,
{% for fn in viewmodel_functions %}        {{ fn.name }} = viewModel::{{ fn.name }},
{% endfor %}    )
}

